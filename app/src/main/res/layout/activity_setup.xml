<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <!-- Logo / Icon -->
    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="24dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trip Tracker v4.0"
        android:textColor="#F1F5F9"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="One-time setup required"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Explanation card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:padding="20dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What Trip Tracker reads from Grab:"
            android:textColor="#F1F5F9"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓  Pickup and dropoff addresses\n✓  Passenger name and service type\n✓  Fare, payment method, promo tags\n✓  Net earnings after trip completes"
            android:textColor="#A7C4A0"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trip Tracker only reads Grab's screen.\nIt cannot control Grab or any other app."
            android:textColor="#64748B"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- Steps -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Steps:\n1. Tap Enable below\n2. Find Trip Tracker in the list\n3. Toggle it ON\n4. Return here and tap Done"
        android:textColor="#CBD5E1"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.6"
        android:layout_marginBottom="24dp" />

    <!-- Status text -->
    <TextView
        android:id="@+id/tvSetupStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Enable button -->
    <Button
        android:id="@+id/btnEnableAS"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Go to Accessibility Settings"
        android:textColor="#FFFFFF"
        android:background="#2D6A4F"
        android:stateListAnimator="@null"
        android:layout_marginBottom="12dp" />

    <!-- Done button -->
    <Button
        android:id="@+id/btnSetupDone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="I've enabled it — Continue"
        android:textColor="#A7C4A0"
        android:background="#16213E"
        android:stateListAnimator="@null" />

</LinearLayout>
